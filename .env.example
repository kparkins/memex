# .env.example -- copy to .env and fill in real values.
#
# `.env` is gitignored; never commit real secrets.
#
# The Memex library does not auto-load .env. Source it yourself
# (`set -a && source .env && set +a`) or pass it to uv:
#     uv run --env-file .env python examples/mongo_usage.py

# --- Backend selection --------------------------------------------------
# "neo4j" (default) or "mongo"
MEMEX_BACKEND=mongo

# --- LLM provider keys (read directly by litellm) -----------------------
# Required by litellm only when the configured embedding/enrichment
# models are served by OpenAI (or Azure OpenAI). When pointing at a
# local OpenAI-compatible server (see "Local embeddings" below), this
# can be any placeholder string -- litellm still checks the env var.
OPENAI_API_KEY=

# --- Embeddings: hosted (default) ---------------------------------------
# OpenAI text-embedding-3-small (1536 dims) is the built-in default.
# MEMEX_EMBEDDING_MODEL=text-embedding-3-small
# MEMEX_EMBEDDING_DIMENSIONS=1536
# MEMEX_EMBEDDING_API_BASE=

# --- Embeddings: local via MLX (Apple Silicon) --------------------------
# Any OpenAI-compatible server that serves an MLX embedding model
# works. Three easy options:
#
#   1. omlx (https://omlx.ai/). Default endpoint http://127.0.0.1:8000/v1
#      Download an embedding model via its admin UI.
#
#   2. LM Studio (GUI). Enable the local server; default endpoint
#      http://localhost:1234/v1
#
#   3. mlx-omni-server (CLI). `pipx install mlx-omni-server && mlx-omni-server`
#      Default endpoint http://localhost:10240/v1
#
# Recommended embedding models from the `mlx-community` org on
# HuggingFace (verified on hf.co):
#
#   mlx-community/bge-m3-mlx-4bit              -> 1024 dims, multilingual
#   mlx-community/mxbai-embed-large-v1         -> 1024 dims, English
#   mlx-community/multilingual-e5-large-mlx    -> 1024 dims, multilingual
#   mlx-community/Qwen3-Embedding-0.6B-mxfp8   -> 1024 dims, newer
#   mlx-community/bge-small-en-v1.5-8bit       -> 384 dims, smallest/fastest
#   mlx-community/Qwen3-Embedding-4B-4bit-DWQ  -> 2560 dims, top MTEB
#
# `MEMEX_EMBEDDING_DIMENSIONS` MUST match what your chosen model
# actually emits -- the Mongo vector index is built to that size and
# a mismatch surfaces as shape errors at query time.
#
# OPENAI_API_KEY=sk-local-unused
# MEMEX_EMBEDDING_MODEL=openai/mlx-community/bge-m3-mlx-4bit
# MEMEX_EMBEDDING_DIMENSIONS=1024
# MEMEX_EMBEDDING_API_BASE=http://127.0.0.1:8000/v1

# --- MongoDB backend ----------------------------------------------------
# For the bundled `docker-compose-mongo.yml` stack:
#   * authentication is enabled (admin:admin by default)
#   * the replica set advertises the Docker-internal hostname
#     `mongod.search-community`, which is unresolvable from the host,
#     so a direct connection is required
MEMEX_MONGO__URI=mongodb://admin:admin@localhost:27017/?directConnection=true&authSource=admin
MEMEX_MONGO__DATABASE=memex

# --- Neo4j backend ------------------------------------------------------
# Only needed if MEMEX_BACKEND=neo4j. The dev password matches the
# value baked into docker-compose for local use; override for anything
# that outlives your laptop.
MEMEX_NEO4J_URI=bolt://localhost:7687
MEMEX_NEO4J_USER=neo4j
MEMEX_NEO4J_PASSWORD=memex_dev_password
MEMEX_NEO4J_DATABASE=neo4j

# --- Redis (working memory, Neo4j backend only) -------------------------
MEMEX_REDIS_URL=redis://localhost:6379/0

# --- Optional tuning knobs (uncomment to override) ----------------------
# MEMEX_ENRICHMENT_MODEL=gpt-4o-mini
# MEMEX_ENRICHMENT_ENABLED=true
# MEMEX_RETRIEVAL_MEMORY_LIMIT=3
# MEMEX_RETRIEVAL_CONTEXT_TOP_K=7
# MEMEX_PRIVACY_PII_REDACTION_ENABLED=true
# MEMEX_ARTIFACT_BACKEND=local
# MEMEX_ARTIFACT_BASE_PATH=./artifacts

# docker/.env.example -- Copy to docker/.env and fill in real values.
#
# NEVER commit docker/.env to version control.

# MongoDB admin credentials (used for MONGODB_INITDB_ROOT_USERNAME/PASSWORD)
MONGO_ADMIN_USERNAME=admin
MONGO_ADMIN_PASSWORD=admin

# Password for the mongotUser account (used by the mongot sidecar)
MONGOT_PASSWORD=mongot

# Optional: Voyage API key for auto-embedding features
# VOYAGE_API_KEY=
